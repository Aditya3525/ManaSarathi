{
  "name": "MaanSarathi - Mental Wellbeing AI",
  "short_name": "MaanSarathi",
  "description": "Your AI-powered companion for mental wellbeing, offering personalized support, assessments, and wellness plans.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#6366f1",
  "orientation": "portrait-primary",
  "scope": "/",
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/favicon.png",
      "sizes": "64x64",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "categories": ["health", "lifestyle", "medical"],
  "screenshots": [
    {
      "src": "/screenshots/dashboard.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    },
    {
      "src": "/screenshots/mobile-dashboard.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ],
  "shortcuts": [
    {
      "name": "AI Chat",
      "short_name": "Chat",
      "description": "Start a conversation with your AI companion",
      "url": "/chat",
      "icons": [
        {
          "src": "/icons/shortcut-chat.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Take Assessment",
      "short_name": "Assess",
      "description": "Complete a mental health assessment",
      "url": "/assessments",
      "icons": [
        {
          "src": "/icons/shortcut-assessment.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Mood Check",
      "short_name": "Mood",
      "description": "Log your current mood",
      "url": "/dashboard",
      "icons": [
        {
          "src": "/icons/shortcut-mood.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
