# Frontend environment variables
# Copy this file to `frontend/.env.local` and fill in the values.

# Points the SPA to the backend API.
VITE_API_URL=http://localhost:5000/api

# Production example (Vercel):
# VITE_API_URL=https://manasarthi-backend.onrender.com/api

# Optional: expose the Google OAuth client for the browser login flow.
# VITE_GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
