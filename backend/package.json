{
  "name": "manasarthi-backend",
  "version": "1.0.0",
  "description": "Backend API for ManaSarathi",
  "main": "dist/bootstrap.js",
  "scripts": {
    "dev": "npm run dev:prepare && nodemon src/bootstrap.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "format": "prettier \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" -w",
    "start": "node dist/bootstrap.js",
    "migrate": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "db:generate": "npm run db:generate:auto",
    "db:generate:auto": "node scripts/prisma-auto.cjs generate",
    "db:generate:auto:if-needed": "node scripts/prisma-auto.cjs generateIfNeeded",
    "db:push:auto": "node scripts/prisma-auto.cjs push",
    "dev:prepare": "npm run db:generate:auto:if-needed && npm run db:push:auto && npm run seed:local && npm run seed:crisis:global",
    "seed:crisis:global": "node scripts/seed-crisis-global.cjs",
    "seed:local": "node scripts/seed-local-demo.cjs",
    "setup:auto": "npm run db:generate:auto && npm run db:push:auto && npm run seed:local && npm run seed:crisis:global",
    "db:studio": "npx tsx scripts/launch-studio.ts",
    "db:studio:direct": "npx prisma studio",
    "db:reset": "npx prisma migrate reset",
    "seed": "ts-node src/prisma/seed.ts",
    "seed:production": "ts-node src/prisma/seed-production.ts",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:ai": "cross-env NODE_ENV=test vitest run tests/llmFallback.test.ts",
    "test:gemini": "cross-env NODE_ENV=test vitest run tests/healthReady.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/inference": "^4.13.10",
    "@prisma/client": "^6.16.2",
    "@types/express-session": "^1.18.2",
    "@types/file-saver": "^2.0.7",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pdfkit": "^0.17.5",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "file-saver": "^2.0.5",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.17.2",
    "pino": "^9.4.0",
    "pino-http": "^10.1.0",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.11.1",
    "yt-search": "^2.13.1",
    "ytdl-core": "^4.11.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.9.0",
    "@types/supertest": "^2.0.16",
    "@vitest/coverage-v8": "^1.5.1",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.1",
    "prettier": "^3.2.5",
    "prisma": "^6.16.2",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vitest": "^1.5.1"
  },
  "keywords": [
    "wellbeing",
    "api",
    "nodejs",
    "express",
    "postgresql",
    "ManaSarathi"
  ],
  "author": "",
  "license": "MIT"
}
