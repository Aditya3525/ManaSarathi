# ============================================================================
# ManaSarathi Backend - Environment Configuration Template
# ============================================================================
# 
# DO NOT commit .env files to version control
# Copy this file to .env.local and populate with your values
# 
# For production: Ensure all required environment variables are set
# ============================================================================

# --- Core Server Configuration ---
NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000
LOG_LEVEL=info

# --- Database Configuration ---
# Development: SQLite (fast, no setup needed)
DATABASE_URL="file:./prisma/dev.db"

# Production: PostgreSQL (recommended)
# DATABASE_URL="postgresql://user:password@localhost:5432/manasarthi_prod"
# Ensure DATABASE_URL has at least 32 character pool and connection timeout settings:
# DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require&connection_timeout=10&statement_timeout=10000"

# --- Frontend & Mobile URLs ---
FRONTEND_URL=http://localhost:5173
MOBILE_URL=http://localhost:8081

# --- Authentication & Security ---
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-32-char-secret-here-replace-with-strong-value
SESSION_SECRET=your-random-32-char-session-secret-here-replace-with-strong-value
JWT_EXPIRE=7d

# --- Admin Configuration ---
ADMIN_EMAILS=admin@example.com,admin@mentalwellbeing.ai
ADMIN_INITIAL_PASSWORD=GenerateSecurePasswordHere123!

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RESEND_VERIFICATION_WINDOW_MS=600000
RESEND_VERIFICATION_MAX_REQUESTS=5

# --- OAuth (Optional) ---
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# --- AI Provider Configuration ---
# Priority order: comma-separated provider names
# Available: huggingface, gemini, openai, anthropic, nvidia, ollama
AI_PROVIDER_PRIORITY=huggingface,gemini,openai,anthropic
AI_ENABLE_FALLBACK=true
AI_USAGE_LOGGING=true
AI_VERBOSE_LOGGING=false  # NEVER enable in production
AI_TIMEOUT=30000
AI_MAX_TOKENS=600
AI_TEMPERATURE=0.6
AI_MAX_DETAIL_ASSESSMENTS=3
AI_MAX_DETAIL_RESPONSES=4
AI_MAX_DETAIL_LENGTH=140
AI_PROVIDER_MAX_FAILURES_BEFORE_COOLDOWN=10
AI_PROVIDER_COOLDOWN_MS=180000

# --- AI Provider API Keys ---
# HuggingFace
HUGGINGFACE_API_KEY_1=your-huggingface-api-key-here
HUGGINGFACE_MODEL=meta-llama/Llama-2-7b-chat-hf

# OpenAI
OPENAI_API_KEY_1=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=600
OPENAI_TEMPERATURE=0.6
OPENAI_TIMEOUT=30000

# Google Gemini
GEMINI_API_KEY_1=your-gemini-api-key-here

# Anthropic
ANTHROPIC_API_KEY_1=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
ANTHROPIC_MAX_TOKENS=600
ANTHROPIC_TEMPERATURE=0.6
ANTHROPIC_TIMEOUT=30000

# --- Email Configuration (Optional) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password-here
# SMTP_FROM=noreply@manasarthi.app

# --- Logging & Monitoring ---
# LOG_LEVEL values: debug, info, warn, error
LOG_LEVEL=info

# --- Cookie Domain (Production) ---
# COOKIE_DOMAIN=.manasarthi.app

# --- CORS Configuration ---
# Additional allowed origins (comma-separated)
# ADDITIONAL_CORS_ORIGINS=https://app.example.com,https://mobile.example.com

# --- Feature Flags ---
ALLOW_VERCEL_PREVIEW_ORIGINS=false
AI_LOCAL_FALLBACK_ENABLED=true  # Enable local fallback for AI in development

# ============================================================================
# PRODUCTION CHECKLIST:
# ============================================================================
# [ ] NODE_ENV=production
# [ ] DATABASE_URL points to PostgreSQL (not SQLite)
# [ ] JWT_SECRET is 32+ chars random (not default)
# [ ] SESSION_SECRET is 32+ chars random (not default)
# [ ] ADMIN_INITIAL_PASSWORD changed (auto-reset after first login)
# [ ] FRONTEND_URL uses HTTPS
# [ ] BACKEND_URL uses HTTPS
# [ ] All AI API keys configured
# [ ] SMTP configured for email notifications
# [ ] LOG_LEVEL set to 'warn' or 'error'
# [ ] AI_VERBOSE_LOGGING=false
# [ ] Secrets stored in environment variables, NOT in code
# [ ] Database backups configured
# [ ] Monitoring & alerting configured
# ============================================================================
