{
  "name": "ManaSarathi-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "reset": "expo start --clear",
    "postinstall": "node scripts/patch-css-interop.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "prebuild": "node scripts/pre-build.js",
    "postbuild": "node scripts/post-build.js",
    "build:dev": "npm run prebuild && eas build --profile development --platform all",
    "build:preview": "npm run prebuild && eas build --profile preview --platform all",
    "build:prod": "npm run prebuild && eas build --profile production --platform all && npm run postbuild",
    "build:ios": "npm run prebuild && eas build --profile production --platform ios && npm run postbuild",
    "build:android": "npm run prebuild && eas build --profile production --platform android && npm run postbuild",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "update:preview": "eas update --branch preview --message \"Preview update\"",
    "update:prod": "eas update --branch production --message \"Production update\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.90.20",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-auth-session": "^7.0.10",
    "expo-av": "^16.0.8",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-device": "^8.0.10",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "^17.0.8",
    "expo-localization": "^17.0.8",
    "expo-location": "^19.0.8",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "^29.0.16",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.8.4",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "victory-native": "^41.20.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.13",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "private": true
}
