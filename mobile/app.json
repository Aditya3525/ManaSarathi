{
  "expo": {
    "name": "MaanSarathi",
    "slug": "MaanSarathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maansarathi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0ea5e9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maansarathi.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely access your mental wellbeing data",
        "NSCameraUsageDescription": "Take photos for your profile",
        "NSPhotoLibraryUsageDescription": "Choose photos from your library",
        "NSMicrophoneUsageDescription": "Record audio for practices"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0ea5e9"
      },
      "package": "com.maansarathi.app",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MaanSarathi to access your photos",
          "cameraPermission": "Allow MaanSarathi to access your camera"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow MaanSarathi to access your microphone for audio practices"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://maansarathi.app"
      },
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
